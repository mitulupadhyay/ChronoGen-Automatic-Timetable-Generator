    "css:watch": "tailwindcss -i ./Frontend/src/input.css -o ./Frontend/output.css --watch"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors":        "^2.8.5",
    "csv-parse":   "^5.5.0",
    "dotenv":      "^17.4.1",
    "express":     "^4.18.2",
    "multer":      "^1.4.5-lts.1",
    "mysql2":      "^3.6.0"
  },
  "devDependencies": {
    "nodemon":    "^3.0.1",
    "tailwindcss":"^3.4.0"
  }
}
