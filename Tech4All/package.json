{
  "name": "chronogen",
  "version": "2.0.0",
  "description": "ChronoGen — Genetic Algorithm Timetable Generator | Team Tech4ALL | Watch The Code 2026",
  "main": "Backend/server.js",
  "scripts": {
    "start":     "node Backend/server.js",
    "dev":       "nodemon Backend/server.js",
